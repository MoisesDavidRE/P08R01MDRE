@model P08R01MVC_Plagas_MDRE.Models.Plaga
@{
    ViewBag.Title = "Detalles de Plaga";
}

<style>
    .details-wrapper {
        animation: scaleIn 0.5s ease-out;
        background: #ffffff;
        border-radius: 12px;
        padding: 30px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        margin-top: 30px;
        border: 1px solid #f0f0f0;
    }
    .details-img {
        border-radius: 12px;
        width: 100%;
        height: auto;
        max-height: 450px;
        object-fit: cover;
        box-shadow: 0 4px 15px rgba(0,0,0,0.1);
    }
    @@keyframes scaleIn {
        from { opacity: 0; transform: scale(0.97); }
        to { opacity: 1; transform: scale(1); }
    }
    .data-label {
        font-weight: bold;
        color: #777;
        text-transform: uppercase;
        font-size: 0.85em;
        letter-spacing: 1px;
        margin-bottom: 5px;
    }
    .data-value {
        font-size: 1.2em;
        margin-bottom: 20px;
        border-bottom: 1px solid #f5f5f5;
        padding-bottom: 10px;
        color: #333;
    }
</style>

<div class="container">
    <div class="details-wrapper row">
        <div class="col-md-5 text-center">
            <img src="@Model.UrlImage" class="details-img" alt="@Model.NombreComun">
        </div>

        <div class="col-md-7" style="padding-left: 30px;">
            <h1 class="text-primary" style="margin-top: 0; font-weight: bold;">@Html.DisplayFor(model => model.NombreComun)</h1>
            <h3 class="text-muted" style="margin-top: 5px; margin-bottom: 20px;"><em>@Html.DisplayFor(model => model.NombreCientifico)</em></h3>
            <hr />

            <div class="row" style="margin-top: 25px;">
                <div class="col-sm-6">
                    <div class="data-label">@Html.DisplayNameFor(model => model.Categoria)</div>
                    <div class="data-value">
                        <span class="label label-info" style="font-size: 90%;">@Html.DisplayFor(model => model.Categoria)</span>
                    </div>
                </div>
                <div class="col-sm-6">
                    <div class="data-label">@Html.DisplayNameFor(model => model.NivelRiesgo)</div>
                    <div class="data-value">
                        <span class="label label-warning" style="font-size: 90%;">@Html.DisplayFor(model => model.NivelRiesgo)</span>
                    </div>
                </div>
            </div>

            <div style="margin-top: 40px;">
                <a href="@Url.Action("Edit", new { id = Model.IdPlaga })" class="btn btn-warning btn-lg">
                    <i class="glyphicon glyphicon-pencil"></i> Editar Plaga
                </a>
                <a href="@Url.Action("Index")" class="btn btn-default btn-lg" style="margin-left: 15px;">
                    <i class="glyphicon glyphicon-list"></i> Volver al Catálogo
                </a>
            </div>
        </div>
    </div>
</div>