@model P08R01MVC_Plagas_MDRE.Models.Prevencion
@{
    ViewBag.Title = "Detalles de Prevención";
}

<style>
    .details-wrapper {
        animation: scaleIn 0.5s ease-out;
        background: #ffffff;
        border-radius: 12px;
        padding: 40px;
        box-shadow: 0 8px 25px rgba(0,0,0,0.08);
        margin-top: 30px;
        border: 1px solid #f0f0f0;
        border-top: 6px solid #5bc0de;
    }

    @@keyframes scaleIn {
        from {
            opacity: 0;
            transform: scale(0.97);
        }

        to {
            opacity: 1;
            transform: scale(1);
        }
    }

    .data-label {
        font-weight: bold;
        color: #777;
        text-transform: uppercase;
        font-size: 0.85em;
        letter-spacing: 1px;
        margin-bottom: 5px;
    }

    .data-value {
        font-size: 1.2em;
        margin-bottom: 25px;
        border-bottom: 1px solid #f5f5f5;
        padding-bottom: 10px;
        color: #333;
    }
</style>

<div class="container">
    <div class="details-wrapper">
        <div class="text-center" style="margin-bottom: 30px;">
            <h1 class="text-primary" style="margin-top: 0; font-weight: bold;">@Html.DisplayFor(model => model.Titulo)</h1>
            <span class="label label-success" style="font-size: 100%;">
                Asociado a Plaga: @Html.DisplayFor(model => model.Plaga.NombreComun)
            </span>
        </div>

        <hr />

        <div class="row" style="margin-top: 25px;">
            <div class="col-md-12">
                <div class="data-label">@Html.DisplayNameFor(model => model.Descripcion)</div>
                <div class="data-value" style="font-size: 1.1em; line-height: 1.6;">
                    @Html.DisplayFor(model => model.Descripcion)
                </div>
            </div>
        </div>

        <div class="text-center" style="margin-top: 40px;">
            <a href="@Url.Action("Edit", new { id = Model.IdPrevencion })" class="btn btn-warning btn-lg">
                <i class="glyphicon glyphicon-pencil"></i> Editar Prevención
            </a>
            <a href="@Url.Action("Index")" class="btn btn-default btn-lg" style="margin-left: 15px;">
                <i class="glyphicon glyphicon-list"></i> Volver al Catálogo
            </a>
        </div>
    </div>
</div>  